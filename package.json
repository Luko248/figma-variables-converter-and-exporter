{
  "name": "figma-css-variables-converter",
  "version": "1.0.0",
  "description": "Figma plugin to convert Figma variables to CSS variables and push to GitHub",
  "main": "code.js",
  "scripts": {
    "build": "npx esbuild src/main.ts --bundle --outfile=code.js --target=es2017 --format=iife --platform=browser && node fix-figma-compat.js",
    "clean": "rm -f code.js && rm -rf dist",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "watch": "npx esbuild src/main.ts --bundle --outfile=code.js --target=es2017 --format=iife --platform=browser --watch"
  },
  "author": "Lukas Chylik",
  "license": "MIT",
  "devDependencies": {
    "@figma/eslint-plugin-figma-plugins": "^1.0.0",
    "@eslint/js": "^10.0.1",
    "@figma/plugin-typings": "^1.125.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^10.2.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "colorizr": "^5.0.1"
  }
}
